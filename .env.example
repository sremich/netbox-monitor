# Optional. Copy to .env and fill in. Never commit .env.
# The app works with NO .env at all — everything can be set in the web UI.
# This file only pre-seeds values on first start.

# Skip the first-run password prompt by setting the web UI password here:
WEBUI_PASSWORD=

# Tokens (only used if you also seed config.yaml from config.example.yaml):
NETBOX_TOKEN=
TECHNITIUM_TOKEN=
PVE_TOKEN=
# Optional: path to the RSA private key registered with the netbox-secrets plugin
SECRETS_KEY_PATH=
# Optional LLDP fallback credentials
UNIFI_SSH_PASSWORD=
SNMP_COMMUNITY=public
